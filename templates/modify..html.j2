{% extends "base.html.j2" %}
{% block title %}修改用户信息{% endblock %}
{% block content %}
<div class="center mb-4">
    <h2>修改用户信息</h2>
</div>
<div class="col-lg-6 offset-lg-3">
    <div class="card mb-4">
        <h5 class="card-header">修改我的选课</h5>
        <div class="card-body">
            <div class="center">
                <form method="POST">
                    <div class="m-3">
                        {% for i,e in must_string %}
                        <div class="form-check form-check-inline">
                            <label class="form-check-label" for="must{{ i + 1 }}">{{ e }}</label>
                            {% if i + 1 in mymust %}
                            <input class="form-check-input musts" type="checkbox" name="mymust" id="must{{ i + 1 }}"
                                value="{{ i + 1 }}" checked>
                            {% else %}
                            <input class="form-check-input musts" type="checkbox" name="mymust" id="must{{ i + 1 }}"
                                value="{{ i + 1 }}">
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                    <input type="hidden" name="csrf" value="{{ csrf }}">
                    <input type="hidden" name="action" value="must">
                    <div class="center mt-2">
                        <button type="submit" class="btn btn-primary">提交</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="card mb-3">
        <h5 class="card-header">
            修改密码
        </h5>
        <div class="card-body">
            {% if error %}
            <div class="center m-3">
                <span class="alert alert-danger" role="alert">
                    <strong>{{ error }}</strong>
                </span>
            </div>
            {% endif %}
            <div class="mt-2 col-sm-6 offset-sm-3">
                <form method="POST" onsubmit="check_password();">
                    <div class="mb-3">
                        <label for="fake_old_password" class="control-label">原密码</label>
                        <input id="fake_old_password" type="password" class="form-control" required>
                        <input id="old_password" type="hidden" name="old_password">
                    </div>
                    <div class="mb-3">
                        <label for="fake_new_password" class="control-label">新密码</label>
                        <input id="fake_new_password" type="password" class="form-control" required>
                        <input id="new_password" type="hidden" name="new_password">
                    </div>
                    <div class="mb-3">
                        <label for="new_password_confirm" class="control-label">确认新密码</label>
                        <input id="new_password_confirm" type="password" class="form-control" required>
                    </div>
                    <input name="csrf" type="hidden" value="{{ csrf }}">
                    <input name="action" type="hidden" value="password">
                    <div class="center">
                        <button type="submit" class="btn btn-primary">提交</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<script src="{{ url_for('static', filename='md5.min.js') }}"></script>
<script>
    function check_password() {
        var old_password = $('#fake_old_password').val();
        var new_password = $('#fake_new_password').val();
        var new_password_confirm = $('#new_password_confirm').val();
        if (new_password != new_password_confirm) {
            swal({
                title: "密码不一致",
                text: "两次输入的密码不一致",
                icon: "error",
            });
            return false;
        }
        $('#old_password').val(md5(old_password));
        $('#new_password').val(md5(new_password));
        return true;
    }
</script>

{% endblock %}